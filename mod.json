{
	"geode": "5.6.1",
	"gd": {
		"win": "2.2081"
	},
	"id": "hexagon80.svg-converter",
	"name": "SVG Converter",
	"version": "0.1.0-beta.4",
	"developer": "Hexagon80",
	"links": { "source": "https://github.com/hexagon80/SVG-Converter" },
	"description": "Converts SVG files  into objects",
	"tags": [ "editor", "utility"],
	"settings":{
		"import":{
			"type": "keybind",
			"category": "editor",
			"requires-restart": false,
			"default":[ "Ctrl+I" ],
			"name": "Import SVG",
			"description": "Imports the svg"
		},
		"speed":{
			"type": "int",
			"default": 300,
			"name": "Import speed",
			"description": "The speed wich objects are generated by objects per tick",
			"max": 10000,
			"min": 50
		}
	},
	"dependencies": {
		"geode.node-ids": ">=v1.23.1"
	}
}
