{
	"geode": "5.5.0",
	"gd": {
		"win": "2.2081"
	},
	"id": "hexagon80.svg-converter",
	"name": "SVG Converter",
	"version": "0.1.0-beta.2",
	"developer": "Hexagon80",
	"links": { "source": "https://github.com/hexagon80/SVG-Converter" },
